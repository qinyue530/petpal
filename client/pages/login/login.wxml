<!-- 登录页面 -->
<view class="container">
  <view class="login-container">
    <view class="login-header">
      <image src="/images/logo.png" mode="aspectFill" class="logo-img" />
      <text class="title">宠物伴侣</text>
      <text class="subtitle">登录/注册</text>
    </view>
    
    <view class="login-form">
      <view class="form-item">
        <text class="form-label">手机号</text>
        <input type="number" placeholder="请输入手机号" class="form-input" bindinput="inputPhone" />
      </view>
      <view class="form-item">
        <text class="form-label">密码</text>
        <input type="password" placeholder="请输入密码" class="form-input" bindinput="inputPassword" />
      </view>
      <view class="form-item">
        <text class="form-label">验证码</text>
        <view class="verify-code">
          <input type="number" placeholder="请输入验证码" class="form-input verify-input" bindinput="inputVerifyCode" />
          <button class="verify-btn" bindtap="sendVerifyCode">{{countdown > 0 ? countdown + 's后重发' : '发送验证码'}}</button>
        </view>
      </view>
      <button class="login-btn" bindtap="login">登录</button>
      <button class="register-btn" bindtap="register">注册</button>
      <view class="forgot-password" bindtap="forgotPassword">
        <text class="forgot-text">忘记密码？</text>
      </view>
      <view class="other-login">
        <text class="other-login-text">其他登录方式</text>
        <view class="login-icons">
          <view class="login-icon-item" bindtap="wechatLogin">
            <image src="/images/wechat-icon.png" mode="aspectFill" class="login-icon" />
            <text class="login-text">微信登录</text>
          </view>
          <view class="login-icon-item" bindtap="phoneLogin">
            <image src="/images/phone-icon.png" mode="aspectFill" class="login-icon" />
            <text class="login-text">手机登录</text>
          </view>
        </view>
      </view>
    </view>
  </view>
</view>