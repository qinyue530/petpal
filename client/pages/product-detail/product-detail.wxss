/* 商品详情页样式 */
.container { padding-bottom: 120rpx; background: #f5f5f5; }

/* 商品图片 */
.product-images { width: 100%; }
.main-image { width: 100%; height: 500rpx; }

/* 价格信息 */
.price-section { background: #fff; padding: 24rpx 30rpx; display: flex; align-items: baseline; }
.price-symbol { font-size: 28rpx; color: #f44336; font-weight: bold; }
.price-value { font-size: 48rpx; color: #f44336; font-weight: bold; margin-right: 20rpx; }
.sales-info { font-size: 24rpx; color: #999; flex: 1; }
.favorite-btn { padding: 8rpx 20rpx; border: 1rpx solid #4CAF50; border-radius: 30rpx; }
.favorite-text { font-size: 24rpx; color: #4CAF50; }

/* 商品标题 */
.title-section { background: #fff; padding: 20rpx 30rpx; border-top: 1rpx solid #f0f0f0; }
.product-title { font-size: 32rpx; font-weight: bold; color: #333; display: block; }
.product-category { font-size: 24rpx; color: #4CAF50; background: #e8f5e9; padding: 4rpx 12rpx; border-radius: 4rpx; margin-top: 10rpx; display: inline-block; }

/* 卡片区域 */
.section-card { background: #fff; padding: 24rpx 30rpx; margin-top: 16rpx; }
.card-label { font-size: 30rpx; font-weight: bold; color: #333; display: block; margin-bottom: 16rpx; }
.card-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 16rpx; }
.card-header .card-label { margin-bottom: 0; }
.rating-text { font-size: 26rpx; color: #ff9800; }

/* 规格选择 */
.spec-list { display: flex; flex-wrap: wrap; gap: 16rpx; margin-bottom: 24rpx; }
.spec-item { padding: 12rpx 24rpx; border: 2rpx solid #e0e0e0; border-radius: 8rpx; font-size: 26rpx; color: #666; }
.spec-item.active { border-color: #4CAF50; color: #4CAF50; background: #e8f5e9; }

/* 数量选择 */
.quantity-row { display: flex; justify-content: space-between; align-items: center; padding-top: 16rpx; border-top: 1rpx solid #f0f0f0; }
.quantity-row .card-label { margin-bottom: 0; }
.quantity-control { display: flex; align-items: center; }
.qty-btn { width: 56rpx; height: 56rpx; border: 1rpx solid #e0e0e0; display: flex; align-items: center; justify-content: center; font-size: 32rpx; color: #666; }
.qty-value { width: 80rpx; text-align: center; font-size: 30rpx; }

/* 商品介绍 */
.product-desc { font-size: 28rpx; color: #666; line-height: 1.8; }

/* 用户评价 */
.review-list { }
.review-item { padding: 20rpx 0; border-bottom: 1rpx solid #f0f0f0; }
.review-item:last-child { border-bottom: none; }
.review-user { display: flex; align-items: center; margin-bottom: 12rpx; }
.review-avatar { width: 64rpx; height: 64rpx; border-radius: 50%; }
.review-user-info { flex: 1; margin-left: 16rpx; }
.review-username { font-size: 26rpx; color: #333; display: block; }
.review-rating { font-size: 22rpx; color: #ff9800; display: block; margin-top: 4rpx; }
.review-time { font-size: 22rpx; color: #999; }
.review-content { font-size: 28rpx; color: #666; line-height: 1.6; padding-left: 80rpx; }
.no-review { text-align: center; padding: 40rpx; color: #999; font-size: 28rpx; }

/* 底部操作栏 */
.bottom-bar { position: fixed; bottom: 0; left: 0; right: 0; display: flex; background: #fff; padding: 16rpx 30rpx; box-shadow: 0 -2rpx 10rpx rgba(0,0,0,0.05); z-index: 100; }
.bar-cart { flex: 1; height: 80rpx; line-height: 80rpx; text-align: center; background: #ff9800; color: #fff; font-size: 28rpx; border-radius: 40rpx 0 0 40rpx; }
.bar-buy { flex: 1; height: 80rpx; line-height: 80rpx; text-align: center; background: #f44336; color: #fff; font-size: 28rpx; border-radius: 0 40rpx 40rpx 0; }
