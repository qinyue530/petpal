/* 工具助手页面样式 */

/* 工具网格 */
.tool-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 20rpx;
  margin-bottom: 24rpx;
}
.tool-item {
  background: #fff;
  border-radius: 16rpx;
  padding: 32rpx 20rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
}
.tool-icon-box {
  width: 96rpx;
  height: 96rpx;
  border-radius: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 16rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.1);
}
.tool-icon-text {
  font-size: 44rpx;
}
.tool-name {
  font-size: 26rpx;
  color: #333;
  font-weight: 600;
}

/* 区域标题 */
.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}
.section-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #333;
}

/* 计算器工具 */
.section {
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
  margin-bottom: 20rpx;
}
.calculator-content {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}
.calculator-item {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}
.calculator-label {
  font-size: 26rpx;
  color: #555;
  font-weight: 600;
}
.calculator-input {
  padding: 16rpx;
  border: 1rpx solid #e0e0e0;
  border-radius: 12rpx;
  font-size: 28rpx;
  background: #f9f9f9;
}
.calculator-picker {
  padding: 16rpx;
  border: 1rpx solid #e0e0e0;
  border-radius: 12rpx;
  font-size: 28rpx;
  color: #333;
  background: #f9f9f9;
}
.calculate-btn {
  padding: 16rpx;
  background: linear-gradient(135deg, #4CAF50, #66BB6A);
  color: #fff;
  border: none;
  border-radius: 30rpx;
  font-size: 28rpx;
  font-weight: 600;
  margin-top: 16rpx;
}
.result {
  margin-top: 20rpx;
  padding: 20rpx;
  background: #f0f9f0;
  border-radius: 12rpx;
  display: flex;
  align-items: center;
  gap: 16rpx;
}
.result-label {
  font-size: 28rpx;
  color: #555;
}
.result-value {
  font-size: 32rpx;
  font-weight: 700;
  color: #4CAF50;
}

/* 训练教程工具 */
.training-content {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}
.training-item {
  background: #f9f9f9;
  border-radius: 12rpx;
  padding: 20rpx;
}
.training-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 8rpx;
  display: block;
}
.training-desc {
  font-size: 26rpx;
  color: #999;
  margin-bottom: 16rpx;
  line-height: 1.5;
  display: block;
}
.training-btn {
  padding: 10rpx 28rpx;
  background: linear-gradient(135deg, #4CAF50, #66BB6A);
  color: #fff;
  border: none;
  border-radius: 30rpx;
  font-size: 24rpx;
  font-weight: 600;
  display: inline-block;
}

/* 健康自查工具 */
.health-content {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}
.health-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx;
  background: #f9f9f9;
  border-radius: 12rpx;
}
.health-symptom {
  font-size: 28rpx;
  color: #333;
  flex: 1;
}
.health-btn {
  padding: 10rpx 28rpx;
  background: linear-gradient(135deg, #4CAF50, #66BB6A);
  color: #fff;
  border: none;
  border-radius: 30rpx;
  font-size: 24rpx;
  font-weight: 600;
}

/* 疫苗提醒工具 */
.vaccine-content {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}
.vaccine-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx;
  background: #f9f9f9;
  border-radius: 12rpx;
}
.vaccine-info {
  flex: 1;
}
.vaccine-name {
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
  display: block;
}
.vaccine-date {
  font-size: 24rpx;
  color: #999;
  display: block;
  margin-top: 4rpx;
}
.vaccine-actions {
  display: flex;
  align-items: center;
  gap: 16rpx;
}
.vaccine-status {
  font-size: 24rpx;
  padding: 6rpx 16rpx;
  border-radius: 20rpx;
  font-weight: 500;
}
.status-pending {
  background: #fff3e0;
  color: #ff9800;
}
.status-done {
  background: #e8f5e9;
  color: #4CAF50;
}
.vaccine-action {
  font-size: 28rpx;
  color: #4CAF50;
  padding: 8rpx;
}
.vaccine-action.delete {
  color: #f44336;
}
.add-vaccine-form {
  display: flex;
  gap: 12rpx;
  margin-top: 16rpx;
  flex-wrap: wrap;
}
.vaccine-input {
  flex: 1;
  min-width: 200rpx;
  padding: 16rpx;
  border: 1rpx solid #e0e0e0;
  border-radius: 12rpx;
  font-size: 26rpx;
  background: #f9f9f9;
}
.date-picker {
  padding: 16rpx;
  border: 1rpx solid #e0e0e0;
  border-radius: 12rpx;
  font-size: 26rpx;
  background: #f9f9f9;
  min-width: 180rpx;
  text-align: center;
  color: #555;
}
.add-vaccine-btn {
  padding: 16rpx 32rpx;
  background: linear-gradient(135deg, #4CAF50, #66BB6A);
  color: #fff;
  border: none;
  border-radius: 30rpx;
  font-size: 26rpx;
  font-weight: 600;
}

/* 弹窗样式 */
.modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1000;
}
.modal-content {
  background: #fff;
  border-radius: 16rpx;
  padding: 32rpx;
  width: 80%;
  max-width: 600rpx;
}
.modal-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #333;
  display: block;
  margin-bottom: 16rpx;
}
.modal-desc {
  font-size: 28rpx;
  color: #999;
  display: block;
  margin-bottom: 20rpx;
  line-height: 1.5;
}
.modal-advice {
  font-size: 28rpx;
  color: #555;
  display: block;
  line-height: 1.6;
  background: #fff8e1;
  padding: 20rpx;
  border-radius: 12rpx;
  margin-bottom: 20rpx;
}
.steps {
  margin-bottom: 20rpx;
}
.steps-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
  display: block;
  margin-bottom: 12rpx;
}
.step {
  display: block;
  font-size: 26rpx;
  color: #555;
  line-height: 2;
  padding-left: 16rpx;
}
.modal-btn {
  padding: 16rpx;
  background: linear-gradient(135deg, #4CAF50, #66BB6A);
  color: #fff;
  border: none;
  border-radius: 30rpx;
  font-size: 28rpx;
  font-weight: 600;
  width: 100%;
}
