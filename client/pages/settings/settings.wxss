.container { padding: 20rpx; }
.section { background: #fff; border-radius: 12rpx; margin-bottom: 20rpx; }
.setting-item { padding: 30rpx 24rpx; display: flex; justify-content: space-between; align-items: center; border-bottom: 1rpx solid #f0f0f0; }
.setting-item:last-child { border-bottom: none; }
.setting-text { font-size: 30rpx; }
.setting-value { font-size: 28rpx; color: #999; }
.arrow { color: #999; }
