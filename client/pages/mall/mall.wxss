/* 商城页面样式 - 温馨可爱风 */

/* ===== 商品部分 ===== */
.product-section {
  margin-top: 8rpx;
}

/* ===== 商品网格 ===== */
.product-grid {
  display: flex;
  flex-wrap: wrap;
  margin: 0 -10rpx;
}

.product-card {
  width: calc(50% - 20rpx);
  margin: 0 10rpx 20rpx 10rpx;
  background: var(--bg-card);
  border-radius: var(--radius-xl);
  overflow: hidden;
  box-shadow: var(--shadow-card);
  border: 2rpx solid var(--border-light);
  transition: transform 0.2s ease;
  box-sizing: border-box;
}

.product-card:active {
  transform: scale(0.97);
}

.product-image-wrap {
  position: relative;
  overflow: hidden;
}

.product-image {
  width: 100%;
  height: 220rpx;
}

.product-badge {
  position: absolute;
  top: 12rpx;
  right: 12rpx;
  background: linear-gradient(135deg, #FF6B6B, #FF8E8E);
  color: #fff;
  font-size: 20rpx;
  font-weight: 700;
  padding: 6rpx 16rpx;
  border-radius: var(--radius-round);
  box-shadow: 0 4rpx 12rpx rgba(255, 107, 107, 0.3);
  letter-spacing: 1rpx;
}

.product-info {
  padding: 18rpx;
}

.product-name {
  font-size: 26rpx;
  color: var(--text-color);
  font-weight: 600;
  display: block;
  margin-bottom: 10rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  line-height: 1.4;
}

.product-bottom {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 14rpx;
}

.product-price-area {
  background: linear-gradient(135deg, #FFF0E8, #FFE0CC);
  padding: 4rpx 16rpx;
  border-radius: var(--radius-round);
}

.product-price {
  font-size: 30rpx;
  font-weight: 800;
  color: var(--primary-dark);
}

.product-sales {
  font-size: 22rpx;
  color: var(--text-light);
}

/* ===== 加入购物车按钮 ===== */
.add-to-cart {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  padding: 12rpx 0;
  background: linear-gradient(135deg, var(--primary-color), var(--secondary-color));
  color: var(--white);
  border: none;
  border-radius: var(--radius-round);
  font-size: 24rpx;
  font-weight: 600;
  text-align: center;
  width: 100%;
  box-shadow: 0 4rpx 12rpx rgba(255, 138, 101, 0.25);
  letter-spacing: 1rpx;
}

.add-to-cart::after {
  border: none;
}

.cart-btn-icon {
  font-size: 24rpx;
}

/* ===== 购物车悬浮按钮 ===== */
.cart-float-btn {
  position: fixed;
  bottom: 120rpx;
  right: 32rpx;
  width: 100rpx;
  height: 100rpx;
  background: linear-gradient(135deg, var(--primary-color), var(--accent-pink));
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8rpx 24rpx rgba(255, 138, 101, 0.4);
  z-index: 100;
  border: 4rpx solid var(--bg-card);
}

.cart-float-icon {
  font-size: 44rpx;
}

.cart-float-count {
  position: absolute;
  top: -6rpx;
  right: -6rpx;
  min-width: 36rpx;
  height: 36rpx;
  background: linear-gradient(135deg, #FF6B6B, #FF8E8E);
  color: #fff;
  border-radius: 18rpx;
  font-size: 20rpx;
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0 8rpx;
  border: 3rpx solid var(--bg-card);
  box-shadow: 0 2rpx 8rpx rgba(255, 107, 107, 0.3);
}
