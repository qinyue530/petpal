/* 首页样式 - 温馨可爱风 */

/* ===== 顶部欢迎横幅 ===== */
.welcome-banner {
  display: flex;
  align-items: center;
  justify-content: space-between;
  background: linear-gradient(135deg, #FF8A65 0%, #FFB74D 50%, #F48FB1 100%);
  border-radius: var(--radius-xl);
  padding: 32rpx 36rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 8rpx 30rpx rgba(255, 138, 101, 0.25);
  position: relative;
  overflow: hidden;
}

.welcome-banner::before {
  content: '';
  position: absolute;
  top: -30rpx;
  right: -20rpx;
  width: 160rpx;
  height: 160rpx;
  background: rgba(255, 255, 255, 0.12);
  border-radius: 50%;
}

.welcome-banner::after {
  content: '';
  position: absolute;
  bottom: -40rpx;
  right: 60rpx;
  width: 100rpx;
  height: 100rpx;
  background: rgba(255, 255, 255, 0.08);
  border-radius: 50%;
}

.welcome-text {
  display: flex;
  flex-direction: column;
  z-index: 1;
}

.welcome-greeting {
  font-size: 36rpx;
  font-weight: 800;
  color: #FFFFFF;
  margin-bottom: 8rpx;
  letter-spacing: 2rpx;
}

.welcome-sub {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.85);
  font-weight: 400;
}

.welcome-paw {
  font-size: 64rpx;
  z-index: 1;
  opacity: 0.9;
  transform: rotate(-15deg);
}

/* ===== 搜索栏（首页增强） ===== */
.search-tip {
  text-align: center;
  padding: 20rpx;
  font-size: 26rpx;
  color: var(--text-light);
  background: var(--bg-card);
  border-radius: var(--radius-md);
  margin-bottom: 20rpx;
  border: 2rpx dashed var(--border-color);
}

/* ===== 导航区域 ===== */
.nav-section {
  background: var(--bg-card);
  border-radius: var(--radius-xl);
  padding: 36rpx 20rpx 28rpx;
  margin-bottom: 24rpx;
  box-shadow: var(--shadow-card);
  border: 2rpx solid var(--border-light);
  position: relative;
}

.nav-section::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 80rpx;
  height: 6rpx;
  background: linear-gradient(90deg, var(--primary-color), var(--accent-pink));
  border-radius: 3rpx;
  opacity: 0.4;
}

.nav-grid {
  display: flex;
  justify-content: space-around;
}

.nav-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  position: relative;
}

.nav-icon {
  width: 100rpx;
  height: 100rpx;
  border-radius: 28rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 12rpx;
  position: relative;
}

/* 每个导航图标的独特渐变色 */
.nav-icon-service {
  background: linear-gradient(135deg, #81C784, #A5D6A7);
  box-shadow: 0 6rpx 20rpx rgba(129, 199, 132, 0.35);
}

.nav-icon-mall {
  background: linear-gradient(135deg, #FFB74D, #FFCC80);
  box-shadow: 0 6rpx 20rpx rgba(255, 183, 77, 0.35);
}

.nav-icon-community {
  background: linear-gradient(135deg, #81D4FA, #B3E5FC);
  box-shadow: 0 6rpx 20rpx rgba(129, 212, 250, 0.35);
}

.nav-icon-tools {
  background: linear-gradient(135deg, #CE93D8, #E1BEE7);
  box-shadow: 0 6rpx 20rpx rgba(206, 147, 216, 0.35);
}

.nav-icon-img {
  width: 50rpx;
  height: 50rpx;
}

.nav-text {
  font-size: 26rpx;
  color: var(--text-color);
  font-weight: 700;
  margin-bottom: 4rpx;
}

.nav-desc {
  font-size: 20rpx;
  color: var(--text-light);
}

/* ===== 服务横向滚动 ===== */
.service-scroll {
  white-space: nowrap;
  margin: 0 -28rpx;
  padding: 0 28rpx;
}

.service-item {
  display: inline-flex;
  flex-direction: column;
  width: 220rpx;
  margin-right: 20rpx;
  vertical-align: top;
  background: var(--bg-warm);
  border-radius: var(--radius-lg);
  overflow: hidden;
  border: 2rpx solid var(--border-light);
}

.service-image-wrap {
  position: relative;
  width: 220rpx;
  height: 150rpx;
}

.service-image {
  width: 220rpx;
  height: 150rpx;
}

.service-tag {
  position: absolute;
  top: 8rpx;
  left: 8rpx;
  background: linear-gradient(135deg, #FF6B6B, #FF8E8E);
  color: #fff;
  font-size: 18rpx;
  font-weight: 700;
  padding: 4rpx 12rpx;
  border-radius: var(--radius-round);
  letter-spacing: 1rpx;
}

.service-info {
  padding: 14rpx 16rpx;
}

.service-name {
  font-size: 26rpx;
  color: var(--text-color);
  font-weight: 600;
  display: block;
  margin-bottom: 8rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.service-bottom {
  display: flex;
  align-items: baseline;
}

.service-price {
  font-size: 32rpx;
  font-weight: 800;
  color: var(--primary-dark);
}

.service-unit {
  font-size: 22rpx;
  color: var(--text-light);
  margin-left: 4rpx;
}

/* ===== 商品网格 ===== */
.product-grid {
  display: flex;
  flex-wrap: wrap;
  margin: 0 -10rpx;
}

.product-card {
  width: calc(50% - 20rpx);
  margin: 0 10rpx 20rpx 10rpx;
  background: var(--bg-warm);
  border-radius: var(--radius-lg);
  overflow: hidden;
  border: 2rpx solid var(--border-light);
  transition: transform 0.2s ease;
  box-sizing: border-box;
}

.product-card:active {
  transform: scale(0.97);
}

.product-image-wrap {
  position: relative;
  overflow: hidden;
}

.product-image {
  width: 100%;
  height: 220rpx;
}

.product-info {
  padding: 18rpx;
}

.product-name {
  font-size: 26rpx;
  color: var(--text-color);
  font-weight: 600;
  display: block;
  margin-bottom: 10rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  line-height: 1.4;
}

.product-bottom {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.product-price-wrap {
  background: linear-gradient(135deg, #FFF0E8, #FFE0CC);
  padding: 4rpx 14rpx;
  border-radius: var(--radius-round);
}

.product-price {
  font-size: 30rpx;
  font-weight: 800;
  color: var(--primary-dark);
}

.product-sales {
  font-size: 22rpx;
  color: var(--text-light);
}

/* ===== 社区动态 ===== */
.community-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.community-card {
  padding: 24rpx;
  background: var(--bg-warm);
  border-radius: var(--radius-lg);
  border: 2rpx solid var(--border-light);
}

.community-user {
  display: flex;
  align-items: center;
  margin-bottom: 16rpx;
}

.community-avatar {
  width: 68rpx;
  height: 68rpx;
  border-radius: 50%;
  margin-right: 16rpx;
  flex-shrink: 0;
  border: 4rpx solid var(--border-light);
}

.community-user-info {
  flex: 1;
}

.community-username {
  font-size: 26rpx;
  font-weight: 700;
  color: var(--text-color);
  display: block;
}

.community-time {
  font-size: 22rpx;
  color: var(--text-light);
  display: block;
  margin-top: 4rpx;
}

.community-text {
  font-size: 26rpx;
  color: var(--text-secondary);
  line-height: 1.7;
  display: block;
  margin-bottom: 16rpx;
}

.community-image {
  width: 100%;
  height: 220rpx;
  border-radius: var(--radius-md);
  margin-bottom: 16rpx;
}

.community-stats {
  display: flex;
  gap: 40rpx;
  padding-top: 12rpx;
}

.stat-item {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.stat-icon {
  font-size: 26rpx;
}

.stat-num {
  font-size: 24rpx;
  color: var(--text-light);
  font-weight: 500;
}

.stat-like .stat-icon {
  filter: hue-rotate(320deg);
}
