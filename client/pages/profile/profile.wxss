/* 个人中心页面样式 - 温馨可爱风 */

/* ===== 用户信息区 ===== */
.user-section {
  display: flex;
  align-items: center;
  background: linear-gradient(135deg, #FF8A65 0%, #FFB74D 50%, #F48FB1 100%);
  border-radius: var(--radius-xl);
  padding: 36rpx 32rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 8rpx 30rpx rgba(255, 138, 101, 0.25);
  overflow: hidden;
  position: relative;
}

.user-section::before {
  content: '';
  position: absolute;
  top: -30rpx;
  right: -20rpx;
  width: 160rpx;
  height: 160rpx;
  background: rgba(255, 255, 255, 0.12);
  border-radius: 50%;
}

.user-section::after {
  content: '';
  position: absolute;
  bottom: -40rpx;
  right: 60rpx;
  width: 100rpx;
  height: 100rpx;
  background: rgba(255, 255, 255, 0.08);
  border-radius: 50%;
}

.user-avatar {
  width: 108rpx;
  height: 108rpx;
  border-radius: 50%;
  border: 5rpx solid rgba(255, 255, 255, 0.6);
  margin-right: 24rpx;
  overflow: hidden;
  flex-shrink: 0;
  z-index: 1;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.1);
}

.avatar-img {
  width: 100%;
  height: 100%;
}

.user-info {
  flex: 1;
  z-index: 1;
}

.user-name {
  font-size: 36rpx;
  font-weight: 800;
  color: #fff;
  margin-bottom: 8rpx;
  display: block;
  letter-spacing: 1rpx;
}

.user-desc {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.85);
}

.login-btn {
  padding: 12rpx 28rpx;
  background: rgba(255, 255, 255, 0.25);
  border-radius: var(--radius-round);
  z-index: 1;
  backdrop-filter: blur(4px);
}

.login-text {
  font-size: 24rpx;
  color: #fff;
  font-weight: 600;
}

/* ===== 区域标题 ===== */
.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: 700;
  color: var(--text-color);
  position: relative;
  padding-left: 20rpx;
}

.section-title::before {
  content: '';
  position: absolute;
  left: 0;
  top: 50%;
  transform: translateY(-50%);
  width: 8rpx;
  height: 32rpx;
  background: linear-gradient(180deg, var(--primary-color), var(--accent-pink));
  border-radius: 4rpx;
}

.section-more {
  font-size: 24rpx;
  color: var(--text-light);
}

/* ===== 宠物列表 ===== */
.pet-list {
  display: flex;
  gap: 16rpx;
  overflow-x: auto;
  padding-bottom: 8rpx;
}

.pet-item {
  flex: 0 0 150rpx;
  background: var(--bg-warm);
  border-radius: var(--radius-lg);
  padding: 20rpx 16rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  border: 2rpx solid var(--border-light);
}

.pet-image {
  width: 84rpx;
  height: 84rpx;
  border-radius: 50%;
  margin-bottom: 10rpx;
  border: 3rpx solid var(--border-light);
}

.pet-name {
  font-size: 24rpx;
  font-weight: 700;
  color: var(--text-color);
  margin-bottom: 4rpx;
}

.pet-type {
  font-size: 20rpx;
  color: var(--text-light);
}

.pet-add {
  flex: 0 0 150rpx;
  background: var(--bg-pink);
  border: 2rpx dashed var(--accent-pink);
  border-radius: var(--radius-lg);
  padding: 20rpx 16rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}

.add-icon-box {
  width: 60rpx;
  height: 60rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, var(--primary-color), var(--accent-pink));
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 8rpx;
  box-shadow: 0 4rpx 12rpx rgba(255, 138, 101, 0.25);
}

.add-icon-text {
  font-size: 32rpx;
  color: #fff;
  font-weight: 700;
}

.add-text {
  font-size: 22rpx;
  color: var(--primary-color);
  font-weight: 600;
}

/* ===== 服务/设置列表 ===== */
.service-list, .setting-list {
  display: flex;
  flex-direction: column;
  border-radius: var(--radius-lg);
  overflow: hidden;
}

.service-item, .setting-item {
  display: flex;
  align-items: center;
  padding: 30rpx 24rpx;
  background: var(--bg-warm);
  border-bottom: 2rpx solid var(--border-light);
  transition: background 0.2s ease;
}

.service-item:last-child, .setting-item:last-child {
  border-bottom: none;
}

.service-item:active, .setting-item:active {
  background: var(--bg-cream);
}

.service-text, .setting-text {
  flex: 1;
  font-size: 28rpx;
  color: var(--text-color);
  font-weight: 500;
}

.arrow-text {
  font-size: 28rpx;
  color: var(--text-light);
}

/* ===== 退出登录 ===== */
.logout-btn {
  margin-top: 32rpx;
  padding: 24rpx;
  background: var(--bg-card);
  border-radius: var(--radius-lg);
  text-align: center;
  box-shadow: var(--shadow-soft);
  border: 2rpx solid var(--border-light);
}

.logout-text {
  font-size: 28rpx;
  color: #FF6B6B;
  font-weight: 600;
}
