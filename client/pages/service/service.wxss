/* 服务页面样式 - 温馨可爱风 */

/* ===== 页面标题区 ===== */
.page-header {
  background: linear-gradient(135deg, #81C784 0%, #A5D6A7 50%, #C8E6C9 100%);
  border-radius: var(--radius-xl);
  padding: 32rpx 36rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 8rpx 30rpx rgba(129, 199, 132, 0.25);
  position: relative;
  overflow: hidden;
}

.page-header::before {
  content: '';
  position: absolute;
  top: -20rpx;
  right: -10rpx;
  width: 120rpx;
  height: 120rpx;
  background: rgba(255, 255, 255, 0.15);
  border-radius: 50%;
}

.page-header::after {
  content: '';
  position: absolute;
  bottom: -30rpx;
  right: 80rpx;
  width: 80rpx;
  height: 80rpx;
  background: rgba(255, 255, 255, 0.1);
  border-radius: 50%;
}

.page-title {
  font-size: 36rpx;
  font-weight: 800;
  color: #FFFFFF;
  display: block;
  margin-bottom: 8rpx;
  letter-spacing: 2rpx;
}

.page-subtitle {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.85);
  display: block;
}

/* ===== 分类部分（覆盖全局） ===== */
.category-section {
  background: var(--bg-card);
  border-radius: var(--radius-xl);
  padding: 18rpx 0;
  margin-bottom: 24rpx;
  box-shadow: var(--shadow-soft);
  border: 2rpx solid var(--border-light);
}

/* ===== 区域标题（覆盖全局） ===== */
.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: 700;
  color: var(--text-color);
  position: relative;
  padding-left: 20rpx;
}

.section-title::before {
  content: '';
  position: absolute;
  left: 0;
  top: 50%;
  transform: translateY(-50%);
  width: 8rpx;
  height: 32rpx;
  background: linear-gradient(180deg, var(--accent-green), var(--accent-mint));
  border-radius: 4rpx;
}

.section-more {
  display: flex;
  align-items: center;
  padding: 8rpx 0;
}

.more-text {
  font-size: 24rpx;
  color: var(--text-light);
}

.more-arrow {
  font-size: 28rpx;
  color: var(--text-light);
  margin-left: 4rpx;
}

/* ===== 商家列表 ===== */
.merchant-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.merchant-item {
  display: flex;
  gap: 20rpx;
  background: var(--bg-warm);
  border-radius: var(--radius-lg);
  padding: 20rpx;
  align-items: center;
  border: 2rpx solid var(--border-light);
  transition: transform 0.2s ease;
}

.merchant-item:active {
  transform: scale(0.98);
}

.merchant-image-wrap {
  flex-shrink: 0;
  border-radius: var(--radius-md);
  overflow: hidden;
  border: 3rpx solid var(--border-light);
}

.merchant-image {
  width: 110rpx;
  height: 110rpx;
  border-radius: var(--radius-md);
}

.merchant-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}

.merchant-name {
  font-size: 28rpx;
  font-weight: 700;
  color: var(--text-color);
}

.merchant-rating-row {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.merchant-rating {
  font-size: 24rpx;
  color: #FFB74D;
  font-weight: 600;
}

.merchant-distance {
  font-size: 22rpx;
  color: var(--accent-green);
  font-weight: 600;
  background: rgba(129, 199, 132, 0.12);
  padding: 2rpx 12rpx;
  border-radius: var(--radius-round);
}

.merchant-address {
  font-size: 22rpx;
  color: var(--text-light);
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

/* ===== 服务列表 ===== */
.service-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.service-item {
  display: flex;
  gap: 20rpx;
  background: var(--bg-warm);
  border-radius: var(--radius-lg);
  padding: 20rpx;
  align-items: center;
  border: 2rpx solid var(--border-light);
  transition: transform 0.2s ease;
}

.service-item:active {
  transform: scale(0.98);
}

.service-image-wrap {
  flex-shrink: 0;
  border-radius: var(--radius-md);
  overflow: hidden;
  border: 3rpx solid var(--border-light);
}

.service-image {
  width: 130rpx;
  height: 130rpx;
  border-radius: var(--radius-md);
}

.service-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}

.service-name {
  font-size: 28rpx;
  font-weight: 700;
  color: var(--text-color);
}

.service-price-row {
  display: flex;
  align-items: baseline;
}

.service-price {
  font-size: 32rpx;
  font-weight: 800;
  color: var(--primary-dark);
}

.service-price-unit {
  font-size: 22rpx;
  color: var(--text-light);
  margin-left: 4rpx;
}

.service-description {
  font-size: 22rpx;
  color: var(--text-light);
  line-height: 1.5;
  overflow: hidden;
  text-overflow: ellipsis;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
}

.service-btn {
  align-self: flex-start;
  padding: 10rpx 24rpx;
  background: linear-gradient(135deg, var(--accent-green), var(--accent-mint));
  color: var(--white);
  border: none;
  border-radius: var(--radius-round);
  font-size: 24rpx;
  font-weight: 600;
  margin-top: 4rpx;
  box-shadow: 0 4rpx 12rpx rgba(129, 199, 132, 0.3);
  letter-spacing: 1rpx;
}

.service-btn::after {
  border: none;
}
