/* 购物车页面样式 */
.page-header {
  padding: 20rpx;
  text-align: center;
  border-bottom: 1rpx solid var(--border-color);
  background-color: var(--white);
}

.page-title {
  font-size: 32rpx;
  font-weight: bold;
  color: var(--text-color);
}

.empty-cart {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 100rpx 0;
}

.empty-text {
  font-size: 28rpx;
  color: var(--text-light);
  margin-bottom: 32rpx;
}

.go-shopping-btn {
  padding: 16rpx 48rpx;
  background-color: var(--primary-color);
  color: var(--white);
  border: none;
  border-radius: 8rpx;
  font-size: 28rpx;
}

.cart-list {
  padding: 20rpx;
}

.cart-item {
  display: flex;
  align-items: center;
  background-color: var(--white);
  border-radius: 8rpx;
  padding: 20rpx;
  margin-bottom: 16rpx;
  box-shadow: 0 2rpx 4rpx rgba(0, 0, 0, 0.05);
}

.cart-item-image {
  width: 120rpx;
  height: 120rpx;
  border-radius: 8rpx;
  margin-right: 20rpx;
}

.cart-item-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.cart-item-name {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--text-color);
}

.cart-item-price {
  font-size: 28rpx;
  color: #f44336;
  font-weight: 600;
}

.cart-item-quantity {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-top: 8rpx;
}

.quantity-btn {
  width: 40rpx;
  height: 40rpx;
  border: 1rpx solid var(--border-color);
  background-color: var(--white);
  border-radius: 4rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
}

.quantity-text {
  font-size: 28rpx;
  color: var(--text-color);
  min-width: 40rpx;
  text-align: center;
}

.delete-btn {
  padding: 8rpx 16rpx;
  background-color: #f44336;
  color: var(--white);
  border: none;
  border-radius: 4rpx;
  font-size: 24rpx;
}

.checkout-section {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background-color: var(--white);
  padding: 20rpx;
  border-top: 1rpx solid var(--border-color);
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.total-price {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.total-label {
  font-size: 28rpx;
  color: var(--text-color);
}

.total-amount {
  font-size: 32rpx;
  color: #f44336;
  font-weight: bold;
}

.checkout-btn {
  padding: 16rpx 48rpx;
  background-color: var(--primary-color);
  color: var(--white);
  border: none;
  border-radius: 8rpx;
  font-size: 28rpx;
  font-weight: 600;
}