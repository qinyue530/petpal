.container { padding: 20rpx; }
.empty { text-align: center; padding: 100rpx 0; }
.empty-text { color: #999; font-size: 28rpx; }
.go-btn { margin-top: 30rpx; background: #4CAF50; color: #fff; }
.favorite-item { background: #fff; border-radius: 12rpx; padding: 20rpx; margin-bottom: 20rpx; display: flex; align-items: center; }
.item-image { width: 120rpx; height: 120rpx; border-radius: 8rpx; }
.item-info { flex: 1; margin-left: 20rpx; }
.item-name { font-size: 28rpx; display: block; }
.item-price { font-size: 32rpx; color: #f44336; font-weight: bold; margin-top: 10rpx; display: block; }
.remove-btn { font-size: 24rpx; color: #999; }
