<!-- 我的收藏 -->
<view class="container">
  <view class="empty" wx:if="{{favorites.length === 0}}">
    <text class="empty-text">暂无收藏商品</text>
    <button class="go-btn" bindtap="goMall">去逛逛商城</button>
  </view>
  <view class="favorite-list" wx:else>
    <view class="favorite-item" wx:for="{{favorites}}" wx:key="id">
      <image src="{{item.image}}" class="item-image" mode="aspectFill" />
      <view class="item-info">
        <text class="item-name">{{item.name}}</text>
        <text class="item-price">¥{{item.price}}</text>
      </view>
      <text class="remove-btn" bindtap="removeFavorite" data-index="{{index}}">取消收藏</text>
    </view>
  </view>
</view>
